Plaintext
# Configuration Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DATABASE_URL=postgres://votre_user:votre_password@localhost:5432/hu_db

# Clés Cryptographiques (À changer absolument en production)
JWT_SECRET=hu_secret_empathy_2024_secure_key
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef # 64 caractères hex pour AES-256

# Configuration Google Cloud (IA & Stockage)
GCP_PROJECT_ID=votre_id_projet
GCS_BUCKET_NAME=votre_bucket_name
GCP_KEY_FILE=./config/google-key.json

# Mapbox
MAPBOX_TOKEN=votre_token_mapbox_public
